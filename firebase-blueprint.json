{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and wallet information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "balance": { "type": "number", "description": "In-app wallet balance" },
        "isVerifiedSeller": { "type": "boolean" },
        "matricNumber": { "type": "string" },
        "hostelAddress": { "type": "string" }
      },
      "required": ["uid", "balance"]
    },
    "Product": {
      "title": "Product",
      "description": "Marketplace item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "hostel": { "type": "string" },
        "image": { "type": "string" },
        "type": { "type": "string", "enum": ["buy", "rent"] },
        "description": { "type": "string" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "condition": { "type": "string" },
        "rating": { "type": "number", "description": "Product rating from 1 to 5" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "sellerId"]
    },
    "Order": {
      "title": "Order",
      "description": "Transaction and escrow record",
      "type": "object",
      "properties": {
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["locked", "released", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["buyerId", "sellerId", "productId", "amount", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User documents"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product listings"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Escrow orders"
    }
  }
}
